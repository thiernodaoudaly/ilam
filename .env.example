# =============================================================
# ILAM — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# =============================================================

COMPOSE_PROJECT_NAME=ilam
ILAM_VERSION=0.1.0

# MinIO
MINIO_ROOT_USER=ilam_admin
MINIO_ROOT_PASSWORD=ilam_password_2025
MINIO_ENDPOINT=http://minio:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Nessie
NESSIE_PORT=19120

# Trino
TRINO_PORT=8080

# Flink
FLINK_JOBMANAGER_PORT=8081
FLINK_PARALLELISM_DEFAULT=2

# PostgreSQL (Airflow backend)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow_password_2025
POSTGRES_DB=airflow
POSTGRES_PORT=5432

# Airflow
AIRFLOW_PORT=8082
AIRFLOW_ADMIN_USER=ilam_admin
AIRFLOW_ADMIN_PASSWORD=ilam_password_2025
AIRFLOW_ADMIN_EMAIL=admin@ilam.io
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow_password_2025@postgres:5432/airflow

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ilam_password_2025
